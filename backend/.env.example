# Backend example env.
# Keep live provider secrets out of backend/.env and backend/.env.local when possible.
# Prefer shell environment variables or hosted secret managers for real credentials.

STOREFRONT_BACKEND_SOURCE=firestore
PORT=4100
CORS_ORIGIN=https://canopytrove.com,https://app.canopytrove.com,https://canopytrove-webapp.web.app
ALLOW_DEV_SEED=false
REQUEST_LOGGING_ENABLED=true
READ_RATE_LIMIT_PER_MINUTE=600
WRITE_RATE_LIMIT_PER_MINUTE=180
ADMIN_RATE_LIMIT_PER_TEN_MINUTES=10

FIREBASE_PROJECT_ID=canopy-trove
FIREBASE_DATABASE_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_SERVICE_ACCOUNT_JSON=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_MAPS_API_KEY=
EXPO_ACCESS_TOKEN=
ADMIN_API_KEY=
OPENAI_API_KEY=# Enables: AI-powered review summaries in owner portal and discovery insights feature
OPENAI_MODEL=gpt-4o-mini
OWNER_PORTAL_PRELAUNCH_ENABLED=false
# Only set OWNER_PORTAL_ALLOWLIST when you intentionally want a private owner rollout.
OWNER_PORTAL_ALLOWLIST=
RUNTIME_AUTO_MITIGATION_ENABLED=true
RUNTIME_INCIDENT_THRESHOLD=3
SENTRY_DSN=# Enables: backend error tracking and performance monitoring
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1
OPS_HEALTHCHECK_ENABLED=false
OPS_HEALTHCHECK_API_URL=
OPS_HEALTHCHECK_API_RAW_URL=
OPS_HEALTHCHECK_SITE_URL=
OPS_HEALTHCHECK_TIMEOUT_MS=8000
OPS_HEALTHCHECK_FAILURE_CONFIRMATION_SWEEPS=2
OPS_HEALTHCHECK_FAILURE_RETRY_COUNT=1
OPS_HEALTHCHECK_FAILURE_RETRY_DELAY_MS=1000
OPS_HEALTHCHECK_INTERVAL_MINUTES=5
OPS_ALERT_WEBHOOK_URL=
OPS_ALERT_COOLDOWN_MINUTES=30
WELCOME_EMAILS_ENABLED=true
EMAIL_DELIVERY_PROVIDER=# Valid values: 'resend' enables email notifications
RESEND_API_KEY=# Enables: welcome emails, billing confirmations, and account notifications via Resend
RESEND_WEBHOOK_SECRET=# Enables: Resend webhook verification and event handling
EMAIL_FROM_ADDRESS=
EMAIL_REPLY_TO_ADDRESS=askmehere@canopytrove.com

STRIPE_SECRET_KEY=# Enables: owner billing and subscription management
STRIPE_WEBHOOK_SECRET=# Enables: payment webhooks and billing event handling
STRIPE_OWNER_MONTHLY_PRICE_ID=
STRIPE_OWNER_ANNUAL_PRICE_ID=
OWNER_BILLING_SUCCESS_URL=https://canopytrove.com/owner/billing/success
OWNER_BILLING_CANCEL_URL=https://canopytrove.com/owner/billing/cancel
OWNER_BILLING_PORTAL_RETURN_URL=https://canopytrove.com/owner/billing
LAUNCH_PROGRAM_START_AT=
LAUNCH_PROGRAM_DURATION_DAYS=183
LAUNCH_EARLY_ADOPTER_LIMIT=500
OWNER_LAUNCH_TRIAL_DAYS=30
