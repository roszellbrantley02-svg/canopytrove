{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "typeRoots": ["./node_modules/@types", "../node_modules/@types"]
  },
  "include": [
    "src/**/*",
    "scripts/**/*",
    "../src/adapters/**/*.ts",
    "../src/data/**/*.ts",
    "../src/domain/**/*.ts",
    "../src/types/**/*.ts",
    "../src/utils/**/*.ts"
  ],
  "exclude": ["../src/**/*.test.ts", "../src/**/*.test.tsx", "../src/utils/crossPlatformAlert.ts"]
}
