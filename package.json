{
  "name": "canopytrove",
  "version": "1.0.2",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "web:build": "npx expo export --platform web && node scripts/post-export.js && node scripts/stamp-sw.js",
    "web:deploy": "npm run web:build && npx firebase-tools deploy --only hosting:webapp",
    "web:preview": "npm run web:build && npx firebase-tools hosting:channel:deploy preview --only webapp",
    "test": "vitest run",
    "test:frontend-core": "vitest run src/services/notificationRoutingService.test.ts src/services/notificationPayloadService.test.ts src/services/analyticsTransport.test.ts src/services/analyticsSessionLifecycle.test.ts src/services/analyticsService.test.ts src/services/displayPerformanceService.test.ts src/services/storefrontMemberDealAccessService.test.ts src/components/HapticPressable.test.tsx src/context/useStorefrontQueryModel.test.tsx src/context/useStorefrontProfileModel.test.tsx src/hooks/storefrontDataHooks.test.tsx src/screens/writeReview/reviewComposerShared.test.ts src/utils/storefrontRatings.test.ts src/screens/ownerPortal/ownerPortalLicenseCompliance.test.ts src/services/ownerPortalProfileToolsMediaService.test.ts src/config/ownerPortalConfig.test.ts src/music/musicPreferenceStorage.test.ts src/music/musicPlayerService.test.ts src/utils/favoriteDealAlerts.test.ts",
    "test:frontend-integration": "vitest run App.test.tsx src/services/postVisitPromptService.test.ts",
    "test:e2e:android:smoke": "powershell -ExecutionPolicy Bypass -File ./scripts/run-android-smoke-e2e.ps1",
    "test:e2e:android:dry-run": "powershell -ExecutionPolicy Bypass -File ./scripts/run-android-smoke-e2e.ps1 -DryRun",
    "android:generate-upload-key": "powershell -ExecutionPolicy Bypass -File ./scripts/generate-android-upload-key.ps1",
    "worktree:summary": "powershell -ExecutionPolicy Bypass -File ./scripts/summarize-worktree.ps1",
    "test:rules": "powershell -ExecutionPolicy Bypass -File ./scripts/run-firebase-rules-tests.ps1",
    "backend": "npm --prefix backend run dev",
    "backend:mock": "powershell -ExecutionPolicy Bypass -File ./scripts/start-backend.ps1 -Source mock",
    "backend:firestore": "powershell -ExecutionPolicy Bypass -File ./scripts/start-backend.ps1 -Source firestore",
    "dev:api": "powershell -ExecutionPolicy Bypass -File ./scripts/start-api-dev.ps1",
    "generate:ocm-verified-seed": "node ./scripts/generate-ocm-verified-seed.mjs",
    "audit:deps": "node ./scripts/audit-deps.mjs",
    "audit:deps:strict": "node ./scripts/audit-deps.mjs --strict",
    "check:staged-secrets": "node ./scripts/check-staged-secrets.mjs",
    "check:all": "npm run precheck:strict && npm test && npm run test:rules && npm --prefix backend test && npm --prefix backend run check",
    "release:check": "node ./scripts/check-release-readiness.mjs --production && npm run lint && npm test && npm run test:rules && npm --prefix backend run check && npm --prefix backend test && npm --prefix backend run release:check -- --production && npm run audit:deps",
    "hosting:firebase:serve": "npx firebase-tools emulators:start --only hosting",
    "hosting:firebase:deploy": "npx firebase-tools deploy --only hosting",
    "lint": "eslint .",
    "lint:strict": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\" \"*.{json,md,js,mjs}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json}\" \"*.{json,md,js,mjs}\"",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "precheck": "npm run typecheck && npm run lint",
    "precheck:strict": "npm run typecheck && npm run lint:strict && npm run format:check"
  },
  "dependencies": {
    "@expo-google-fonts/dm-sans": "^0.4.2",
    "@expo-google-fonts/space-grotesk": "^0.4.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "11.5.2",
    "@react-native-firebase/app": "^22.0.0",
    "@react-native-firebase/app-check": "^22.0.0",
    "@react-navigation/bottom-tabs": "^7.15.7",
    "@react-navigation/native": "^7.2.0",
    "@react-navigation/native-stack": "^7.14.7",
    "@sentry/react-native": "~7.11.0",
    "@shopify/react-native-skia": "2.4.18",
    "expo": "~55.0.15",
    "expo-asset": "~55.0.15",
    "expo-audio": "~55.0.13",
    "expo-build-properties": "~55.0.13",
    "expo-camera": "~55.0.15",
    "expo-dev-client": "~55.0.27",
    "expo-document-picker": "~55.0.13",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.8",
    "expo-image-picker": "~55.0.18",
    "expo-linear-gradient": "~55.0.13",
    "expo-location": "~55.1.8",
    "expo-notifications": "~55.0.19",
    "expo-secure-store": "~55.0.13",
    "expo-status-bar": "~55.0.5",
    "expo-task-manager": "~55.0.14",
    "expo-updates": "~55.0.20",
    "firebase": "^12.11.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.2"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@testing-library/react-native": "^13.2.0",
    "@types/react": "~19.2.2",
    "@types/react-test-renderer": "^19.1.0",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "babel-preset-expo": "^55.0.17",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-native": "^5.0.0",
    "firebase-tools": "^15.13.0",
    "husky": "^9.1.0",
    "lint-staged": "^16.1.0",
    "prettier": "^3.5.0",
    "react-refresh": "^0.14.2",
    "react-test-renderer": "19.2.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.1"
  },
  "overrides": {
    "@hono/node-server": "^1.19.13",
    "basic-ftp": "^5.2.2",
    "hono": "^4.12.12"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
