{
  "expo": {
    "name": "Canopy Trove",
    "slug": "canopytrove",
    "scheme": "canopytrove",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/icon-v2.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon-v2.png",
      "resizeMode": "contain",
      "backgroundColor": "#121614"
    },
    "ios": {
      "supportsTablet": false,
      "icon": "./assets/ios-icon-v2.png",
      "bundleIdentifier": "com.rezell.canopytrove",
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": ["C617.1", "0A2A.1", "3B52.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryDiskSpace",
            "NSPrivacyAccessedAPITypeReasons": ["E174.1", "85F4.1"]
          }
        ]
      },
      "associatedDomains": [
        "applinks:canopytrove.com",
        "applinks:www.canopytrove.com",
        "applinks:app.canopytrove.com"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Canopy Trove uses your camera to scan QR codes, barcodes, and storefront license identifiers for on-the-spot verification.",
        "NSMicrophoneUsageDescription": "Canopy Trove does not record audio. This entry is required by iOS because the audio playback library we use links the microphone framework for completeness.",
        "NSPhotoLibraryUsageDescription": "Canopy Trove uses your photo library only when you choose review photos to attach before they enter the private moderation queue.",
        "NSLocationWhenInUseUsageDescription": "Canopy Trove uses your location to find nearby licensed storefronts and let you share how your visit was when you arrive."
      },
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "icon": "./assets/android-icon.png",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.rezell.canopytrove",
      "googleServicesFile": "./google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "canopytrove.com",
              "pathPrefix": "/storefronts/"
            },
            {
              "scheme": "https",
              "host": "www.canopytrove.com",
              "pathPrefix": "/storefronts/"
            },
            {
              "scheme": "https",
              "host": "app.canopytrove.com",
              "pathPrefix": "/storefronts/"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA"
      ],
      "blockedPermissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "name": "Canopy Trove",
      "shortName": "Canopy Trove",
      "description": "Discover verified licensed storefronts and trusted reviews near you.",
      "lang": "en",
      "themeColor": "#121614",
      "backgroundColor": "#121614"
    },
    "plugins": [
      "@react-native-firebase/app",
      "@react-native-firebase/app-check",
      [
        "expo-camera",
        {
          "cameraPermission": "Canopy Trove uses your camera to scan QR codes, barcodes, and storefront license identifiers for on-the-spot verification."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Canopy Trove uses your location to find nearby licensed storefronts and let you share how your visit was when you arrive."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Canopy Trove uses your photos so you can attach review images that stay private until moderation approves them.",
          "cameraPermission": "Canopy Trove uses your camera so you can take review photos before they enter the private moderation queue.",
          "microphonePermission": false
        }
      ],
      [
        "expo-notifications",
        {
          "defaultChannel": "post-visit-follow-up"
        }
      ],
      "expo-font",
      "@sentry/react-native",
      "expo-audio",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "buildToolsVersion": "36.0.0"
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ]
    ],
    "owner": "rezell",
    "extra": {
      "eas": {
        "projectId": "681bbd78-2840-4906-b9e9-01b4f7c99bcb"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/681bbd78-2840-4906-b9e9-01b4f7c99bcb"
    }
  }
}
