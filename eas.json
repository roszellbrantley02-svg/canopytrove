{
  "cli": {
    "version": ">= 18.4.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "environment": "development",
      "channel": "development",
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "NODE_ENV": "development",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    },
    "preview": {
      "environment": "preview",
      "channel": "preview",
      "distribution": "internal",
      "env": {
        "NODE_ENV": "production",
        "EXPO_PUBLIC_OWNER_PORTAL_PRELAUNCH_ENABLED": "true",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    },
    "production": {
      "environment": "production",
      "autoIncrement": true,
      "channel": "production",
      "distribution": "store",
      "env": {
        "NODE_ENV": "production",
        "EXPO_PUBLIC_OWNER_PORTAL_PRELAUNCH_ENABLED": "true",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "$EAS_ANDROID_SERVICE_ACCOUNT_KEY_PATH",
        "track": "internal"
      }
    }
  }
}
