{
  "cli": {
    "version": ">= 18.4.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "environment": "development",
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "NODE_ENV": "development"
      }
    },
    "preview": {
      "environment": "preview",
      "distribution": "internal",
      "env": {
        "NODE_ENV": "production",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true",
        "EXPO_PUBLIC_OWNER_PORTAL_PREVIEW_ENABLED": "true",
        "EXPO_PUBLIC_STOREFRONT_SOURCE": "api",
        "EXPO_PUBLIC_STOREFRONT_API_BASE_URL": "https://api.canopytrove.com"
      }
    },
    "production": {
      "environment": "production",
      "autoIncrement": true,
      "env": {
        "NODE_ENV": "production",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
