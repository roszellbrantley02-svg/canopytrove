rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        (request.auth.token.admin == true || request.auth.token.role == 'admin');
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /owner-private/{ownerUid}/{allPaths=**} {
      allow read, write: if isAdmin() || isSelf(ownerUid);
    }

    match /dispensary-media/{dispensaryId}/approved/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /dispensary-media/{dispensaryId}/pending/{ownerUid}/{allPaths=**} {
      allow read, write: if isAdmin() || isSelf(ownerUid);
    }

    match /deals-media/{dispensaryId}/{dealId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() || isSignedIn();
    }
  }
}
