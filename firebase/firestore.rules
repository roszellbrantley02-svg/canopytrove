rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function hasRoleClaim(role) {
      return isSignedIn() &&
        (('role' in request.auth.token) && request.auth.token.role == role);
    }

    function isAdmin() {
      return isSignedIn() &&
        ((('admin' in request.auth.token) && request.auth.token.admin == true) ||
          hasRoleClaim('admin'));
    }

    function isOwner(uid) {
      return isSelf(uid) && hasRoleClaim('owner');
    }

    function businessVerificationDoc(uid) {
      return get(/databases/$(database)/documents/businessVerifications/$(uid));
    }

    function identityVerificationDoc(uid) {
      return get(/databases/$(database)/documents/identityVerifications/$(uid));
    }

    function subscriptionDoc(uid) {
      return get(/databases/$(database)/documents/subscriptions/$(uid));
    }

    function hasWritableUserRole(uid) {
      return request.resource.data.role == 'customer' ||
        (request.resource.data.role == 'owner' && isOwner(uid)) ||
        (request.resource.data.role == 'admin' && isAdmin());
    }

    function ownsDispensary(dispensaryId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/dispensaries/$(dispensaryId)) &&
        get(/databases/$(database)/documents/dispensaries/$(dispensaryId)).data.ownerUid == request.auth.uid;
    }

    function ownerVerified(uid) {
      return exists(/databases/$(database)/documents/businessVerifications/$(uid)) &&
        exists(/databases/$(database)/documents/identityVerifications/$(uid)) &&
        businessVerificationDoc(uid).data.verificationStatus in ['verified', 'approved'] &&
        identityVerificationDoc(uid).data.verificationStatus in ['verified', 'approved'];
    }

    function ownerSubscribed(uid, dispensaryId) {
      return exists(/databases/$(database)/documents/subscriptions/$(uid)) &&
        subscriptionDoc(uid).data.status in ['trial', 'active'] &&
        subscriptionDoc(uid).data.dispensaryId == dispensaryId;
    }

    function isDefaultOwnerProfileCreate(uid) {
      return request.resource.data.uid == uid &&
        request.resource.data.dispensaryId == null &&
        request.resource.data.businessVerificationStatus == 'unverified' &&
        request.resource.data.identityVerificationStatus == 'unverified' &&
        request.resource.data.subscriptionStatus == 'inactive' &&
        request.resource.data.badgeLevel == 0 &&
        request.resource.data.earnedBadgeIds == [] &&
        request.resource.data.selectedBadgeIds == [];
    }

    function preservesOwnerProfileControlledFields() {
      return request.resource.data.uid == resource.data.uid &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.dispensaryId == resource.data.dispensaryId &&
        request.resource.data.businessVerificationStatus == resource.data.businessVerificationStatus &&
        request.resource.data.identityVerificationStatus == resource.data.identityVerificationStatus &&
        request.resource.data.subscriptionStatus == resource.data.subscriptionStatus &&
        request.resource.data.badgeLevel == resource.data.badgeLevel &&
        request.resource.data.earnedBadgeIds == resource.data.earnedBadgeIds &&
        request.resource.data.selectedBadgeIds == resource.data.selectedBadgeIds;
    }

    function isOwnerDealSubmission() {
      return request.resource.data.ownerUid == request.auth.uid &&
        request.resource.data.moderationStatus == 'pending' &&
        request.resource.data.reviewedAt == null &&
        request.resource.data.reviewNotes == null;
    }

    function preservesDealControlledFields() {
      return request.resource.data.ownerUid == resource.data.ownerUid &&
        request.resource.data.dispensaryId == resource.data.dispensaryId &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.moderationStatus == resource.data.moderationStatus &&
        request.resource.data.reviewedAt == resource.data.reviewedAt &&
        request.resource.data.reviewNotes == resource.data.reviewNotes;
    }

    match /users/{uid} {
      allow create: if isSelf(uid) &&
        request.resource.data.uid == uid &&
        hasWritableUserRole(uid);
      allow read: if isSelf(uid) || isAdmin();
      allow update: if isAdmin() || (
        isSelf(uid) &&
        request.resource.data.uid == resource.data.uid &&
        hasWritableUserRole(uid)
      );
      allow delete: if isAdmin();
    }

    match /ownerProfiles/{uid} {
      allow create: if isAdmin() || (
        isOwner(uid) &&
        isDefaultOwnerProfileCreate(uid)
      );
      allow read: if isSelf(uid) || isAdmin();
      allow update: if isAdmin() || (
        isOwner(uid) &&
        preservesOwnerProfileControlledFields()
      );
      allow delete: if isAdmin();
    }

    match /dispensaries/{dispensaryId} {
      allow read: if resource.data.listingStatus in ['public', 'active'];
      allow create: if isAdmin();
      allow update: if isAdmin() || (
        ownsDispensary(dispensaryId) &&
        request.resource.data.ownerUid == resource.data.ownerUid &&
        request.resource.data.licenseNumber == resource.data.licenseNumber &&
        request.resource.data.licenseType == resource.data.licenseType &&
        request.resource.data.claimStatus == resource.data.claimStatus &&
        request.resource.data.averageRating == resource.data.averageRating &&
        request.resource.data.reviewCount == resource.data.reviewCount
      );
      allow delete: if isAdmin();
    }

    match /dispensaryClaims/{claimId} {
      allow create: if isSignedIn() &&
        claimId == request.auth.uid + '_' + request.resource.data.dispensaryId &&
        request.resource.data.ownerUid == request.auth.uid &&
        request.resource.data.claimStatus == 'pending' &&
        request.resource.data.reviewedAt == null &&
        request.resource.data.reviewNotes == null &&
        isOwner(request.auth.uid);
      allow read: if isAdmin() || (
        isSignedIn() && resource.data.ownerUid == request.auth.uid
      );
      allow update, delete: if isAdmin();
    }

    match /businessVerifications/{verificationId} {
      allow create: if isSignedIn() &&
        verificationId == request.auth.uid &&
        request.resource.data.ownerUid == request.auth.uid &&
        request.resource.data.verificationStatus == 'pending' &&
        request.resource.data.adminNotes == null &&
        request.resource.data.reviewedAt == null &&
        request.resource.data.verificationSource == 'owner_upload' &&
        isOwner(request.auth.uid);
      allow read: if isAdmin() || (
        isSignedIn() && resource.data.ownerUid == request.auth.uid
      );
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /identityVerifications/{verificationId} {
      allow create: if isSignedIn() &&
        verificationId == request.auth.uid &&
        request.resource.data.ownerUid == request.auth.uid &&
        request.resource.data.verificationStatus == 'pending' &&
        request.resource.data.provider == 'manual_review' &&
        request.resource.data.providerReferenceId == null &&
        request.resource.data.adminNotes == null &&
        request.resource.data.reviewedAt == null &&
        isOwner(request.auth.uid);
      allow read: if isAdmin() || (
        isSignedIn() && resource.data.ownerUid == request.auth.uid
      );
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /subscriptions/{subscriptionId} {
      allow read: if isAdmin() || (
        isSignedIn() && resource.data.ownerUid == request.auth.uid
      );
      allow create, update, delete: if isAdmin();
    }

    match /deals/{dealId} {
      allow read: if resource.data.status == 'active' &&
        resource.data.moderationStatus == 'approved';
      allow create: if isSignedIn() &&
        isOwnerDealSubmission() &&
        ownsDispensary(request.resource.data.dispensaryId) &&
        ownerVerified(request.auth.uid) &&
        ownerSubscribed(request.auth.uid, request.resource.data.dispensaryId);
      allow update: if isAdmin() || (
        isSignedIn() &&
        resource.data.ownerUid == request.auth.uid &&
        ownsDispensary(resource.data.dispensaryId) &&
        preservesDealControlledFields() &&
        ownerVerified(request.auth.uid) &&
        ownerSubscribed(request.auth.uid, resource.data.dispensaryId)
      );
      allow delete: if isAdmin();
    }

    match /storefrontPhotos/{photoId} {
      allow read: if (resource.data.approved == true && resource.data.moderationStatus == 'approved') ||
        isAdmin() ||
        (isSignedIn() && resource.data.ownerUid == request.auth.uid);
      allow create: if isSignedIn() &&
        request.resource.data.ownerUid == request.auth.uid &&
        ownsDispensary(request.resource.data.dispensaryId) &&
        ownerVerified(request.auth.uid) &&
        ownerSubscribed(request.auth.uid, request.resource.data.dispensaryId);
      allow update, delete: if isAdmin();
    }

    match /storefront_review_photos/{mediaId} {
      allow create: if isSignedIn() &&
        request.resource.data.profileId == request.auth.uid &&
        request.resource.data.moderationStatus == 'pending';
      allow read: if isAdmin() || (
        isSignedIn() && resource.data.profileId == request.auth.uid
      );
      allow update, delete: if isAdmin();
    }

    match /badges/{badgeId} {
      allow read: if resource.data.active == true || isAdmin();
      allow write: if isAdmin();
    }

    match /badgeProgress/{ownerUid} {
      allow read: if isSelf(ownerUid) || isAdmin();
      allow write: if isAdmin();
    }

    match /ownerTasks/{taskId} {
      allow read: if isAdmin() || isOwner(resource.data.ownerUid);
      allow write: if isAdmin();
    }

    match /auditLogs/{logId} {
      allow read, write: if isAdmin();
    }

    match /adminActions/{actionId} {
      allow read, write: if isAdmin();
    }

    match /analytics_events/{eventId} {
      allow read, write: if isAdmin();
    }

    match /analytics_daily_app_metrics/{docId} {
      allow read, write: if isAdmin();
    }

    match /analytics_daily_storefront_metrics/{docId} {
      allow read, write: if isAdmin();
    }

    match /analytics_daily_deal_metrics/{docId} {
      allow read, write: if isAdmin();
    }

    match /analytics_daily_search_metrics/{docId} {
      allow read, write: if isAdmin();
    }

    match /analytics_daily_signup_metrics/{docId} {
      allow read, write: if isAdmin();
    }

    match /analytics_daily_query_metrics/{docId} {
      allow read, write: if isAdmin();
    }

    match /storefront_app_reviews/{reviewId} {
      allow create: if isSignedIn() &&
        request.resource.data.profileId == request.auth.uid &&
        request.resource.data.text.size() <= 2000 &&
        request.resource.data.authorName.size() <= 100;
      allow read: if isSignedIn();
      allow update: if isSignedIn() &&
        resource.data.profileId == request.auth.uid;
      allow delete: if isSignedIn() &&
        resource.data.profileId == request.auth.uid;
    }

    match /gamification_state/{docId} {
      allow read: if isSelf(docId) || isAdmin();
      allow write: if isAdmin();
    }
  }
}
